#postgres
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
#jwt
SECRET_KEY=your_secret_key
ALGORITHM=HS256
TOKEN_EXP_TIME=30

TMDB_API_KEY=tmdb_api_key
# 개발 환경에서는 development, 배포 환경에서는 production으로 설정
ENVIRONMENT=development
# CORS_ORIGINS는 비워두거나, 배포 시 쓸 고정 주소만 작성
# 고정 주소는 나중에 swagger 사용시나 테스트 페이지 사용 환경의 ip로 설정하면 됨(혹은 웹으로 확장할 경우 웹사이트 주소로)
CORS_ORIGINS=your_ip_address